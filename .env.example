# Copy this file only if you want to configure Tebis by hand.
# The easier path is `tebis setup`.

# Bot token from @BotFather. Treat it like a password.
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME

# Your numeric Telegram user ID from @userinfobot.
# Tebis ignores messages from everyone else.
TELEGRAM_ALLOWED_USER=0

# Optional: restrict which terminal sessions Tebis may control.
# Leave unset or empty to allow any valid session name.
# Names may contain letters, numbers, dots, underscores, and hyphens.
TELEGRAM_ALLOWED_SESSIONS=claude-code,shell

# Optional: start a default agent the first time you send plain text.
# Set all three values together.
# TELEGRAM_AUTOSTART_SESSION=claude-code
# TELEGRAM_AUTOSTART_DIR=/path/to/your/project
# TELEGRAM_AUTOSTART_COMMAND=claude

# Optional: install supported Claude Code or Copilot CLI hooks for the
# default project so replies arrive faster.
# TELEGRAM_HOOKS_MODE=auto

# Optional: local dashboard on http://127.0.0.1:<port>.
# Do not expose this port to other machines.
# INSPECT_PORT=51624

# Optional: voice notes in Telegram become text sent to the agent.
# TELEGRAM_STT=on
# TELEGRAM_STT_MODEL=small.en

# Optional: read agent replies back as Telegram voice messages.
# Use `say` on macOS, `winrt` on Windows, or Kokoro backends.
# TELEGRAM_TTS_BACKEND=off
# TELEGRAM_TTS_VOICE=
# TELEGRAM_TTS_RESPOND_TO_ALL=off

# Optional tuning.
# TELEGRAM_POLL_TIMEOUT=30
# TELEGRAM_MAX_OUTPUT_CHARS=4000
# TELEGRAM_AUTOREPLY=on
# TELEGRAM_NOTIFY=on
