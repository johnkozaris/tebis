# Bot token from @BotFather — treat as secret, never commit a filled version.
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME

# Numeric user id (ask @userinfobot). Only this user is authorized.
# Usernames are NOT accepted — they are recyclable (CVE-2026-28480).
TELEGRAM_ALLOWED_USER=0

# Comma-separated tmux session names. Each must match [A-Za-z0-9._-]{1,64}.
TELEGRAM_ALLOWED_SESSIONS=claude-code,shell

# Optional tuning:
# TELEGRAM_POLL_TIMEOUT=30       # long-poll seconds
# TELEGRAM_MAX_OUTPUT_CHARS=4000 # capture-pane truncation cap

# Outbound-notify (on by default). A local Unix-domain socket the agent
# hook scripts push summaries to, which the bridge forwards as a Telegram
# message. UDS-only — not reachable from the network. chat_id defaults to
# TELEGRAM_ALLOWED_USER.
#
# TELEGRAM_NOTIFY=off              # Disable the listener entirely
# NOTIFY_CHAT_ID=0                 # Override destination chat id
# NOTIFY_SOCKET_PATH=              # Default: $XDG_RUNTIME_DIR/tebis.sock
                                   # Fallback: /tmp/tebis-$USER.sock

# Autostart (optional). When all three are set, the first plain-text message
# that arrives with no /target selected will create a detached tmux session
# with the given name, cd to DIR, run COMMAND (e.g. `claude`), wait for the
# TUI to come up, set it as the default target, and forward the message.
# Session name must appear in TELEGRAM_ALLOWED_SESSIONS.
#
# TELEGRAM_AUTOSTART_SESSION=claude-code
# TELEGRAM_AUTOSTART_DIR=/path/to/your/project
# TELEGRAM_AUTOSTART_COMMAND=claude

# Inspect dashboard (optional). If set, the bridge binds 127.0.0.1:<port>
# with a local-only HTML control panel. No authentication — localhost only.
# Shows: config, live tmux sessions, activity metrics (last message time,
# last response duration, counts), handler in-flight count. Includes a
# CSRF-protected "kill all allowlisted sessions" button.
#
# INSPECT_PORT=51624

# Agent hooks mode (optional). When `auto` AND autostart.command is a
# known agent (claude, copilot-cli), tebis writes that agent's hook
# config into the autostart directory at session spawn so replies arrive
# via the agent's native Stop event — no pane-settle polling. Fails open:
# if install fails, pane-settle takes over silently.
#
# TELEGRAM_HOOKS_MODE=auto
