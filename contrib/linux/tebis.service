# User-scoped systemd unit: install to ~/.config/systemd/user/tebis.service
#   systemctl --user daemon-reload
#   systemctl --user enable --now tebis
# Enable lingering so the service runs without an active login session:
#   sudo loginctl enable-linger "$USER"
#
# Env file (mode 0600): ~/.config/tebis/env
#   TELEGRAM_BOT_TOKEN=...
#   TELEGRAM_ALLOWED_USER=...
#   TELEGRAM_ALLOWED_SESSIONS=claude-code,shell
#
# `systemd-analyze --user security tebis` to audit.

[Unit]
Description=tebis — Telegram-tmux bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/tebis
EnvironmentFile=%h/.config/tebis/env
# Tell the bridge where to write when the inspect dashboard edits
# settings. Without this, the Settings panel displays as disabled.
Environment=BRIDGE_ENV_FILE=%h/.config/tebis/env
# `always` (not `on-failure`) so the Restart button in the inspect
# dashboard — which exits the bridge cleanly via SIGTERM-equivalent —
# also triggers a respawn. Save-and-restart from Settings relies on this.
Restart=always
RestartSec=5

# The optional outbound-notify socket binds at $XDG_RUNTIME_DIR/tebis.sock
# (mode 0600, UDS — not reachable over the network). $XDG_RUNTIME_DIR is
# writable by user units without extra config; the daemon unlinks stale
# sockets on startup, so no RuntimeDirectory= is required.

# Sandboxing
# NB: we DO NOT set PrivateTmp — the tmux server socket lives in /tmp/tmux-$UID
# by default and a private /tmp would hide it. If you move the socket (tmux -S),
# re-enable PrivateTmp and BindPaths= the socket back in.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
# `ProtectHome=read-only` blocks writes to %h/. The inspect dashboard
# Settings panel writes to the env file; carve out exactly that dir.
ReadWritePaths=%h/.config/tebis
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectProc=invisible
ProcSubset=pid
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources
UMask=0077

# Logging — journal captures stdout/stderr; no file rotation needed.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
